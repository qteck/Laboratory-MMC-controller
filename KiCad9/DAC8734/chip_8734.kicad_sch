		(uuid "72bfd565-3a90-4a8e-950a-95641e5686d3")
	)
	(text "LDAC \nPIN LOW - Individual DAC Channel Update \n=GPIO-0: LOW (Register Set to 0)\nPIN HIGH - Simultaneous DAC Channels Update\n=GPIO-1: HIGH (Register Set to 1)"
		(exclude_from_sim no)
		(at 299.974 41.91 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "7c62fabe-9375-4859-9977-54602e3e1145")
	)
	(text "UNI/BIP-A -> IOVdd: SETS UNIPOLAR (REF-A)\nUNI/BIP-B -> IOVdd: SETS UNIPOLAR (REF-B)\n\nGROUP A\nDAC 0 AND DAC 1\n\nGROUP B\nDAC 2 AND DAC 3"
		(exclude_from_sim no)
		(at 372.364 132.08 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "cd6f64dd-2e47-41fa-b68b-cd9f3271ed0c")
	)
