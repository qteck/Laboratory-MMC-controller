	)
	(text "MAX VREF FOR USED POWER SUPPLY (VREF = 2V)\nAVdd >= 2*Vref + 1\nAVss <= -2*Vref - 1 \n\nAVdd >= 2*2+1 = 5V\nAVss <= -2*2 - 1 = -5V "
		(exclude_from_sim no)
		(at 372.11 56.134 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "2f9219c0-cfa6-44a0-9fa9-8bec2a8196ca")
	)
	(text "VMON\nVmon should be measured only with high impedance load to not excceed Vmon I limits.\nThe Vmon can be set digitally to multiplex between AIN, DAC0,1,2,3 or is OFF.\n\n- could monitor outputs and feed it into MCU for remote monitoring. This would require ADC with +-10V inputs, \nor redution in amplitude using opamp or voltage divider"
		(exclude_from_sim no)
		(at 299.212 12.954 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "3a7ae2a7-e02b-436e-b451-05a78feb18bf")
	)
	(text "POWER/REF SUPPLY\nAVdd = +5V\nAVss = -5V\nIOVdd = +1.8V to 5V\nREF-A = +1V8\nREF-B = +1V8\n\nREGISTER\nGAIN-0 = '0'\nGAIN-1 = '0'\nGAIN-2 = '0'\nGAIN-3 = '0'\n\nGAIN:\nDAC-0 = 2x\nDAC-1 = 2x\nDAC-2 = 2x\nDAC-3 = 2x\n\nVOUT\nVOUT-0: 1V8*2 = +3.6V\nVOUT-1: 1V8*2 = +3.6V\nVOUT-2: 1V8*2 = +3.6V\nVOUT-3: 1V8*2 = +3.6V"
		(exclude_from_sim no)
		(at 371.856 92.71 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
