	(text "Wattage for the I2C pull up resistors\nMAX I = 5 / 4.7K = 1.064 mA\nMAX P = I * V = 1064u * 5 = 5.32 mW\n\nP = V^2 / R = 5^2 / 4.7k = 5.32 mW"
		(exclude_from_sim no)
		(at 300.482 108.712 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "0aa6d815-ebc7-4723-97e6-f617f35cb4b8")
	)
	(text "ADC\nVREF sets the voltage referance. This is the FS of the ADC. It is a stable reference that doesnt fluctuate. \nFor single ended configuration and bipolar input, the signal needs to be level shifted and divided to fit the ADC specs.\n\nThe FSB can be set using registers to fit the maximum input voltages. "
		(exclude_from_sim no)
		(at 300.228 35.052 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "112ca106-5226-48d6-8e57-cc3832ccab58")
	)
