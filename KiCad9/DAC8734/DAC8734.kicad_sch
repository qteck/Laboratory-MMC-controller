	(text "-check the pin out for the spi \n-check the voltages \n-vmon needs other a connector - a wee hole - for further design \nor devide the voltage by 4 and implement small duck, add i2c isolator and feed it to the mcu. \n\ncheck whether all the pins can do i2c pulled up to 5V. On the mcu side, the isolators should be connected to 3.3v"
		(exclude_from_sim no)
		(at 298.196 92.456 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "0523189f-e184-4f1d-89f1-d94436de6728")
	)
	(text "3.3V"
		(exclude_from_sim no)
		(at 45.212 27.686 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "0c001264-2354-4859-a0e8-3618b4c61764")
	)
	(text "The resistences on the coaxial lines are added to protect the low impedance output of the DAC \nagainst the capacitive effects of the coax lines.\n\nThere is no need for matching network. The input impedance of the load is expected to be 1M ohms. \nLost magnitude will be tiny.\n\nReflections neglected because line is short, its impedance is small.\nThe expected wavelength lambda = v/f = 3000m. \n\nCable length << lambda/10 = 300m - Lumped"
		(exclude_from_sim no)
		(at 300.228 15.24 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "4482d358-04a6-409c-9b85-152f5b3334d2")
	)
	(text "3.3V"
		(exclude_from_sim no)
		(at 45.466 104.14 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "6012cf79-7871-4801-9fc3-a8da7ef68ab9")
	)
	(text "The vout-x traces are matched to 50ohms single ended impedance. \nThe matching is not neccessary but the coax cables are 50 ohms, as well as the connector. \n"
		(exclude_from_sim no)
		(at 301.244 44.958 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "b81109c2-b080-4114-bec6-c3b7569124bc")
	)
	(text "!! The coax output can connect only to high input impedance. \n!! Conneting it to 50ohms exceeds the current limits."
		(exclude_from_sim no)
		(at 300.99 38.1 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "cc0bf855-fdfb-42f3-b308-88792da222fc")
	)
