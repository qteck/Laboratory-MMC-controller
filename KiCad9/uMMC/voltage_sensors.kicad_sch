	(text "	A1	 A0    Address 	\nGND  GND   1000000 	0x40\nGND  VS    1000001 	0x41\nGND  SCL   1000011 	0x43\nVS   GND   1000100 	0x44\nVS   VS    1000101 	0x45\nVS   SCL   1000111 	0x47\n\nA → 0x40\nB → 0x41\nC → 0x43\nD → 0x44\nE → 0x45\nF → 0x47"
		(exclude_from_sim no)
		(at 366.014 -4.572 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "0ef1f250-8053-4872-b8e9-36f4a5215978")
	)
	(text "Considering current: I = 1A \n\nMax I = +-40A; Integrated shunt is 0.0008 ohms; \nMax voltage: 40*0.0008 = 32mV \n\nFor positive and negative polarity:\nFS: 64mV/(2^16) = 0.976μV\n\nPositive polarity:\nFS: 32mV/32768 = 0.976μV\n\nConsidering 1A the Vdrop is 1A*0.0008ohms\n800μV/0.976μV = 819.7 steps for I = 1A\n\nThe lowest measurable I when one step can be sampled is at I = 1.22mV\n\nIn this design, I>1A is expected."
		(exclude_from_sim no)
		(at 298.704 57.15 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "1e22ee79-1df0-4e4e-909f-c1616c8a4eab")
	)
	(text "I = 5mA"
		(exclude_from_sim no)
		(at 157.48 61.214 90)
		(effects
			(font
				(size 0.762 0.762)
			)
		)
		(uuid "268c4a14-0152-461c-b7c8-b564e276b98b")
	)
	(text "No Isolation"
		(exclude_from_sim no)
		(at 305.308 -14.224 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "32177efe-acdb-44d6-a49f-c3f29a5b9e5e")
	)
	(text "I = 5mA"
