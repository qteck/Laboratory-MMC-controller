	)
	(text "Programmable conversion and time averaging\nIntegrated Shunt = 800μΩ\nSignam ADC = 16Bit"
		(exclude_from_sim no)
		(at 298.958 2.032 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
