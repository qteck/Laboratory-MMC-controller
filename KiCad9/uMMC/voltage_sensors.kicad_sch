		(uuid "46fe6b14-a76f-463e-8f34-8ade52defad8")
	)
	(text "ADC conversion\ntimes from 50μs to 4.12ms as well as sample\naveraging from 1x to 1024x"
		(exclude_from_sim no)
		(at 299.212 -7.366 0)
