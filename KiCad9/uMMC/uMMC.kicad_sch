	)
	(text "CAPACITANCE OF TRACE \n- SLOW DOWN EDGES - ADDS SLEW RATE\n- TR = R*C_TRACE\nINDUCTANCE\n- INTRODUCES RINGING, OVERSHOOT, UNDERSHOOT\n-TRACE HAVE SELF INDUCTANCE - v=l*DI/DT\n-FAST EDGES -?LARGE DI/DT - LARGE VOLTAGE SPIKES\n\n-COMBINED WITH CAPACITANCE RESULTS IN LC - RINGING, RESONATING\n-ADDING SERIES DUMPING RESISTORS - REDUCE RINGING\n\nTrace capacitance slows edges (RC effect), while trace inductance causes ringing and overshoot (LC effect)."
		(exclude_from_sim no)
		(at -191.262 4.318 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "d1e55789-7d1c-41d6-bdd0-d2633648af90")
	)
